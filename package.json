{
  "name": "fourth-pyramid-backend",
  "version": "1.0.0",
  "description": "Supabase backend for the Fourth Pyramid Industrial Ecosystem",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "db:pull": "npx supabase db pull",
    "db:diff": "npx supabase db diff",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "supabase:status": "npx supabase status",
    "types:gen": "npx supabase gen types typescript --local > src/lib/types/database.types.ts",
    "functions:serve": "npx supabase functions serve",
    "functions:deploy": "npx supabase functions deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^8.0.8"
  }
}
