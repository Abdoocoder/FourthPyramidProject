# =============================================================================
# FOURTH PYRAMID INDUSTRIAL ECOSYSTEM — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Supabase Edge Function Secrets ────────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# (Do NOT put these in .env — they live only in the Supabase vault)
#
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # auto-injected in Edge Functions
# SUPABASE_ANON_KEY=<anon-key>                   # auto-injected in Edge Functions
# RESEND_API_KEY=re_xxxxxxxxxxxx                  # get from resend.com
# ADMIN_EMAIL=info@fourthpyramid.com             # where admin notifications go
# FROM_EMAIL=noreply@fourthpyramid.com           # sender address (must be verified in Resend)

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Fourth Pyramid Industrial Ecosystem
VITE_APP_URL=http://localhost:5173
